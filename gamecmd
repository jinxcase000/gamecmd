#!/bin/bash

# gamecmd - Steam launch option manager
# Usage: gamecmd <profile> %command%

# 1. Read profile label from first argument
PROFILE=$1
shift

# 2. Path to YAML configuration file
YAML_FILE="$HOME/.config/gamecmd/games.yaml"

# 3. Check if yq is installed
if ! command -v yq &> /dev/null; then
    echo "Error: 'yq' is not installed. Please run the install script."
    exit 1
fi

# 4. Check if config file exists
if [ ! -f "$YAML_FILE" ]; then
    echo "Error: Config file not found at $YAML_FILE"
    exit 1
fi

# 5. Extract values from YAML
ENV_STRING=$(yq -r ".$PROFILE.env_vars // \"\"" "$YAML_FILE")
PREFIX_CMD=$(yq -r ".$PROFILE.prefix // \"\"" "$YAML_FILE")
SUFFIX_ARGS=$(yq -r ".$PROFILE.suffix // \"\"" "$YAML_FILE")

# 6. Verify profile exists
if [ "$ENV_STRING" = "null" ]; then
    echo "Error: Profile '$PROFILE' not found in $YAML_FILE"
    exit 1
fi

# 7. Launch game with env vars, prefix commands, game command, and suffix args
if [ "$GAMECMD_DEBUG" = "1" ]; then
    echo "ENV: $ENV_STRING"
    echo "PREFIX: $PREFIX_CMD"
    echo "SUFFIX: $SUFFIX_ARGS"
fi
env $ENV_STRING $PREFIX_CMD "$@" $SUFFIX_ARGS
